{
    "name": "odysee.com",
    "version": "0.0.0",
    "description": "Explore a whole universe of videos on Odysee from regular people just like you!",
    "keywords": [
        "odysee"
    ],
    "homepage": "https://odysee.com",
    "bugs": {
        "url": "https://github.com/OdyseeTeam/odysee-frontend/issues"
    },
    "license": "MIT",
    "author": {
        "name": "Odysee Inc.",
        "email": "hello@odysee.com"
    },
    "repository": {
        "type": "git",
        "url": "https://github.com/OdyseeTeam/odysee-frontend"
    },
    "type": "module",
    "scripts": {
        "dev": "vp dev",
        "build": "vp build",
        "preview": "vp preview",
        "check": "vp check",
        "check:fix": "vp check --fix",
        "lint": "cross-env NODE_OPTIONS=--experimental-strip-types vp lint",
        "lint:fix": "cross-env NODE_OPTIONS=--experimental-strip-types vp lint --fix",
        "fmt": "vp fmt",
        "fmt:check": "vp fmt --check",
        "typecheck": "cross-env NODE_OPTIONS=--experimental-strip-types vp lint --type-aware --type-check",
        "dev:web-server": "cross-env NODE_ENV=development concurrently --kill-others \"vp build --watch\" \"cd web && pnpm dev:server\"",
        "run:web-server": "cross-env NODE_ENV=production vp build && cd web && pnpm dev:server",
        "postinstall": "cd web && pnpm install",
        "test:e2e": "playwright test",
        "test:e2e:ui": "playwright test --ui",
        "test:e2e:debug": "playwright test --debug",
        "test:e2e:headed": "playwright test --headed",
        "test:e2e:report": "playwright show-report playwright-report",
        "test:e2e:codegen": "playwright codegen http://localhost:1337",
        "test:e2e:smoke": "playwright test --project=chromium tests/specs/smoke",
        "test:e2e:auth": "playwright test --project=chromium:auth tests/specs/authenticated"
    },
