  "repository": {
    "type": "git",
    "url": "https://github.com/OdyseeTeam/odysee-frontend"
  },
  "type": "module",
  "scripts": {
    "dev": "vp dev",
    "build": "vp build",
    "preview": "vp preview",
    "check": "vp check",
    "check:fix": "vp check --fix",
    "lint": "node node_modules/.pnpm/oxlint@1.55.0_oxlint-tsgolint@0.17.0/node_modules/oxlint/bin/oxlint -c .oxlintrc.json .",
    "lint:fix": "node node_modules/.pnpm/oxlint@1.55.0_oxlint-tsgolint@0.17.0/node_modules/oxlint/bin/oxlint -c .oxlintrc.json --fix .",
    "fmt": "vp fmt",
    "fmt:check": "vp fmt --check",
    "typecheck": "node node_modules/.pnpm/oxlint@1.55.0_oxlint-tsgolint@0.17.0/node_modules/oxlint/bin/oxlint -c .oxlintrc.json --type-aware --type-check .",
    "typecheck:tsc": "tsc --noEmit",
    "dev:web-server": "cross-env NODE_ENV=development node scripts/dev-web-server.mjs",
    "run:web-server": "cross-env NODE_ENV=production vp build && cd web && pnpm dev:server",
    "postinstall": "cd web && pnpm install",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:debug": "playwright test --debug",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:report": "playwright show-report playwright-report",
    "test:e2e:codegen": "playwright codegen http://localhost:1337",
    "test:e2e:smoke": "playwright test --project=chromium tests/specs/smoke",
    "test:e2e:auth": "playwright test --project=chromium:auth tests/specs/authenticated"
  },
