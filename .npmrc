# Enforce the Node.js version declared in package.json#engines.
# pnpm will refuse to install if the active Node version does not satisfy ^22.0.0.
engine-strict=true

# Hoist all packages to the root node_modules so that tools that rely on
# a flat dependency tree (e.g. some Webpack/Vite plugins, PostCSS plugins)
# can resolve them without needing explicit declarations.
shamefully-hoist=true
